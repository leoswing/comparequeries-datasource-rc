{
  "name": "leoswing-comparequeries-datasource",
  "version": "2.2.0",
  "description": "Grafana plugin for compare queries",
  "scripts": {
    "build": "webpack -c ./.config/webpack/webpack.config.ts --env production",
    "dev": "webpack -w -c ./.config/webpack/webpack.config.ts --env development",
    "test": "jest --watch --onlyChanged",
    "test:ci": "jest --passWithNoTests --maxWorkers 4",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --cache --ignore-path ./.gitignore --ext .js,.jsx,.ts,.tsx .",
    "lint:fix": "npm run lint -- --fix",
    "e2e": "playwright test",
    "server": "docker-compose up --build",
    "server:matrix:up": "bash scripts/grafana-matrix.sh up",
    "server:matrix:status": "bash scripts/grafana-matrix.sh status",
    "server:matrix:down": "bash scripts/grafana-matrix.sh down",
    "sign": "npx --yes @grafana/sign-plugin@latest"
  },
  "author": "Mit",
  "license": "Apache-2.0",
  "devDependencies": {
    "@babel/core": "^7.21.4",
    "@grafana/eslint-config": "^7.0.0",
    "@grafana/plugin-e2e": "1.2.0",
    "@grafana/tsconfig": "^1.2.0-rc1",
    "@playwright/test": "^1.41.2",
    "@swc/core": "^1.3.90",
    "@swc/helpers": "^0.5.0",
    "@swc/jest": "^0.2.26",
    "@testing-library/jest-dom": "6.1.4",
    "@testing-library/react": "14.0.0",
    "@types/jest": "^29.5.0",
    "@types/lodash": "^4.14.194",
    "@types/node": "^20.8.7",
    "@types/react-router-dom": "^5.2.0",
    "@types/testing-library__jest-dom": "5.14.8",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^6.7.3",
    "eslint-plugin-deprecation": "^2.0.0",
    "eslint-webpack-plugin": "^4.0.1",
    "fork-ts-checker-webpack-plugin": "^8.0.0",
    "glob": "^10.2.7",
    "identity-obj-proxy": "3.0.0",
    "imports-loader": "^5.0.0",
    "jest": "^30.0.0",
    "jest-environment-jsdom": "^30.0.0",
    "prettier": "^2.8.7",
    "replace-in-file-webpack-plugin": "^1.0.6",
    "sass": "1.63.2",
    "sass-loader": "13.3.1",
    "style-loader": "3.3.3",
    "swc-loader": "^0.2.3",
    "terser-webpack-plugin": "^5.6.0",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "5.9.2",
    "webpack": "^5.86.0",
    "webpack-cli": "^5.1.4",
    "webpack-livereload-plugin": "^3.0.2",
    "webpack-subresource-integrity": "^5.1.0",
    "webpack-virtual-modules": "^0.6.2"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@emotion/css": "11.10.6",
    "@grafana/data": "11.6.14",
    "@grafana/runtime": "11.6.14",
    "@grafana/schema": "11.6.14",
    "@grafana/ui": "11.6.14",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "tslib": "2.5.3"
  },
  "packageManager": "npm@8.19.3",
  "overrides": {
    "minimatch": "^9.0.8",
    "dompurify": "^3.4.2",
    "lodash": "^4.18.1",
    "immutable": "^5.1.5",
    "uuid": "^11.1.1"
  }
}
